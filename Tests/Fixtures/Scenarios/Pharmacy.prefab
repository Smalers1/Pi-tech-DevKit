    \u03C4\u03B9\u03C2 \u03B1\u03C0\u03B1\u03C1\u03B1\u03AF\u03C4\u03B7\u03C4\u03B5\u03C2
    \u03C0\u03BB\u03B7\u03C1\u03BF\u03C6\u03BF\u03C1\u03AF\u03B5\u03C2 \u03B3\u03B9\u03B1
    \u03C0\u03AC\u03C1\u03BF\u03C5\u03BC\u03B5 \u03B2\u03B1\u03C3\u03B9\u03BA\u03AD\u03C2
    \u03B1\u03C0\u03BF\u03C6\u03AC\u03C3\u03B5\u03B9\u03C2 \u03B3\u03B9\u03B1 \u03C4\u03BF\u03BD
    \u03B1\u03C3\u03B8\u03B5\u03BD\u03AE \u03C0\u03BF\u03C5 \u03AD\u03C7\u03BF\u03C5\u03BC\u03B5

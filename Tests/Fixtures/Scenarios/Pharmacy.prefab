  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u039F\u03B9 \u03BA\u03BB\u03B5\u03B9\u03C3\u03C4\u03AD\u03C2 \u03B5\u03C1\u03C9\u03C4\u03AE\u03C3\u03B5\u03B9\u03C2,
    \u03C0\u03BF\u03C5 \u03BF\u03B9 \u03B1\u03C0\u03B1\u03BD\u03C4\u03AE\u03C3\u03B5\u03B9\u03C2
    \u03B5\u03AF\u03BD\u03B1\u03B9 \u03C4\u03CD\u03C0\u03BF\u03C5 \u039D\u0391\u0399/\u039F\u03A7\u0399
    \u03B5\u03AF\u03BD\u03B1\u03B9 \u03C5\u03C0\u03BF\u03B2\u03AD\u03BB\u03C4\u03B9\u03C3\u03C4\u03BF\u03C2
    \u03C4\u03C1\u03CC\u03C0\u03BF\u03C2 \u03B1\u03BE\u03B9\u03BF\u03BB\u03CC\u03B3\u03B7\u03C3\u03B7\u03C2
    \u03C3\u03C5\u03BC\u03C0\u03C4\u03C9\u03BC\u03AC\u03C4\u03C9\u03BD \u03B3\u03B9\u03B1\u03C4\u03AF
    \u03BA\u03B1\u03B8\u03BF\u03B4\u03B7\u03B3\u03BF\u03CD\u03BD \u03C4\u03BF\u03BD
    \u03B1\u03C3\u03B8\u03B5\u03BD\u03AE \u03BA\u03B1\u03B9 \u03B4\u03B5\u03BD \u03C4\u03BF\u03C5
    \u03B5\u03C0\u03B9\u03C4\u03C1\u03AD\u03C0\u03BF\u03C5\u03BD \u03BD\u03B1 \u03B5\u03BA\u03C6\u03C1\u03AC\u03C3\u03B5\u03B9
    \u03B1\u03C5\u03B8\u03CC\u03C1\u03BC\u03B7\u03C4\u03B1 \u03C4\u03B7\u03BD \u03B1\u03C4\u03BF\u03BC\u03B9\u03BA\u03AE
    \u03B5\u03BC\u03C0\u03B5\u03B9\u03C1\u03AF\u03B1 \u03C4\u03BF\u03C5 \u03B1\u03C0\u03CC
    \u03C4\u03B7\u03BD \u03BA\u03B1\u03C4\u03AC\u03C3\u03C4\u03B1\u03C3\u03B7 \u03C0\u03BF\u03C5
    \u03B2\u03B9\u03CE\u03BD\u03B5\u03B9. \u03A0\u03C1\u03BF\u03C4\u03B9\u03BC\u03AC\u03C4\u03B1\u03B9
    \u03C3\u03C5\u03BD\u03AE\u03B8\u03C9\u03C2 \u03B7 \u03C7\u03C1\u03AE\u03C3\u03B7
    \u03B1\u03BD\u03BF\u03B9\u03BA\u03C4\u03BF\u03CD \u03C4\u03CD\u03C0\u03BF\u03C5
    \u03B5\u03C1\u03C9\u03C4\u03AE\u03C3\u03B5\u03C9\u03BD \u03C0\u03BF\u03C5 \u03B5\u03C0\u03B9\u03C4\u03C1\u03AD\u03C0\u03BF\u03C5\u03BD

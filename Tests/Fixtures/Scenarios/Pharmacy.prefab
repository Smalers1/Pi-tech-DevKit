  m_text: "\u0397 \u03B5\u03C1\u03CE\u03C4\u03B7\u03C3\u03B7 \u03B1\u03C5\u03C4\u03AE,
    \u03BC\u03B1\u03B6\u03AF \u03BC\u03B5 \u03C4\u03B7\u03BD \u03C0\u03B5\u03C1\u03B9\u03B3\u03C1\u03B1\u03C6\u03AE
    \u03C4\u03C9\u03BD \u03C3\u03C5\u03BC\u03C0\u03C4\u03C9\u03BC\u03AC\u03C4\u03C9\u03BD,
    \u03BC\u03B1\u03C2 \u03B2\u03BF\u03B7\u03B8\u03AC\u03B5\u03B9 \u03BD\u03B1 \u03BA\u03B1\u03C4\u03B1\u03BD\u03BF\u03AE\u03C3\u03BF\u03C5\u03BC\u03B5
    \u03C4\u03B7\u03BD \u03AD\u03BD\u03C4\u03B1\u03C3\u03B7 \u03BA\u03B1\u03B9 \u03C4\u03B7
    \u03C3\u03BF\u03B2\u03B1\u03C1\u03CC\u03C4\u03B7\u03C4\u03B1 \u03C4\u03B7\u03C2
    \u03BA\u03B1\u03C4\u03AC\u03C3\u03C4\u03B1\u03C3\u03B7\u03C2, \u03BA\u03B1\u03B8\u03CE\u03C2
    \u03BA\u03B1\u03B9 \u03C4\u03BF \u03C0\u03CC\u03C3\u03BF \u03C7\u03C1\u03BF\u03BD\u03BF\u03B5\u03C5\u03B1\u03AF\u03C3\u03B8\u03B7\u03C4\u03B7
    \u03B5\u03AF\u03BD\u03B1\u03B9 \u03B7 \u03B1\u03BD\u03C4\u03B9\u03BC\u03B5\u03C4\u03CE\u03C0\u03B9\u03C3\u03AE
    \u03C4\u03B7\u03C2."

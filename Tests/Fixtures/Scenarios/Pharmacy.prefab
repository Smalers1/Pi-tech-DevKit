  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0391\u03BD \u03BA\u03B1\u03B9 \u03B8\u03B1 \u03BC\u03B1\u03C2 \u03C0\u03C1\u03BF\u03C3\u03C6\u03AD\u03C1\u03B5\u03B9
    \u03BC\u03B9\u03B1 \u03C3\u03B7\u03BC\u03B1\u03BD\u03C4\u03B9\u03BA\u03AE \u03C0\u03BB\u03B7\u03C1\u03BF\u03C6\u03BF\u03C1\u03AF\u03B1
    \u03C0\u03BF\u03C5 \u03B8\u03B1 \u03BC\u03B1\u03C2 \u03B2\u03BF\u03B7\u03B8\u03AE\u03C3\u03B5\u03B9
    \u03BD\u03B1 \u03B1\u03C0\u03BF\u03BA\u03BB\u03B5\u03AF\u03C3\u03BF\u03C5\u03BC\u03B5
    \u03BA\u03AC\u03C0\u03BF\u03B9\u03B5\u03C2 \u03B5\u03C0\u03B9\u03BB\u03BF\u03B3\u03AD\u03C2
    \u03C6\u03B1\u03C1\u03BC\u03B1\u03BA\u03B5\u03C5\u03C4\u03B9\u03BA\u03AE\u03C2
    \u03C0\u03B1\u03C1\u03AD\u03BC\u03B2\u03B1\u03C3\u03B7\u03C2 , \u03B5\u03AF\u03BD\u03B1\u03B9
    \u03B5\u03C1\u03CE\u03C4\u03B7\u03C3\u03B7 \u03BA\u03BB\u03B5\u03B9\u03C3\u03C4\u03BF\u03CD
    \u03C4\u03CD\u03C0\u03BF\u03C5 \u03C0\u03BF\u03C5 \u03BA\u03B1\u03B8\u03BF\u03B4\u03B7\u03B3\u03B5\u03AF
    \u03C4\u03BF\u03BD \u03B1\u03C3\u03B8\u03B5\u03BD\u03AE \u03BD\u03B1 \u03B1\u03C0\u03B1\u03BD\u03C4\u03AE\u03C3\u03B5\u03B9
    \u03BC\u03CC\u03BD\u03BF \u03C3\u03C7\u03B5\u03C4\u03B9\u03BA\u03AC \u03BC\u03B5
    \u03C4\u03B9\u03C2 \u03C3\u03C7\u03B5\u03C4\u03B9\u03BA\u03AD\u03C2 \u03C6\u03B1\u03C1\u03BC\u03B1\u03BA\u03B5\u03C5\u03C4\u03B9\u03BA\u03AD\u03C2
    \u03B1\u03B3\u03C9\u03B3\u03AD\u03C2 \u03C0\u03B1\u03C1\u03B1\u03BB\u03B5\u03AF\u03C0\u03BF\u03BD\u03C4\u03B1\u03C2
    \u03C0\u03B9\u03B8\u03B1\u03BD\u03CE\u03C2 \u03AC\u03BB\u03BB\u03B5\u03C2 \u03C0\u03B1\u03C1\u03B5\u03BC\u03B2\u03AC\u03C3\u03B5\u03B9\u03C2
    \u03C0\u03BF\u03C5 \u03BC\u03C0\u03BF\u03C1\u03B5\u03AF \u03BD\u03B1 \u03AD\u03C7\u03B5\u03B9
    \u03B4\u03BF\u03BA\u03B9\u03BC\u03AC\u03C3\u03B5\u03B9."

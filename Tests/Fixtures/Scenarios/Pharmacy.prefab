  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u039C\u03B1\u03C2 \u03BB\u03B5\u03AF\u03C0\u03BF\u03C5\u03BD \u03C0\u03BF\u03BB\u03CD
    \u03C3\u03B7\u03BC\u03B1\u03BD\u03C4\u03B9\u03BA\u03AD\u03C2 \u03C0\u03BB\u03B7\u03C1\u03BF\u03C6\u03BF\u03C1\u03AF\u03B5\u03C2.
    \u0395\u03C0\u03B9\u03C0\u03C1\u03CC\u03C3\u03B8\u03B5\u03C4\u03B1 \u03BF \u03C4\u03C1\u03CC\u03C0\u03BF\u03C2
    \u03BC\u03B5 \u03C4\u03BF\u03BD \u03BF\u03C0\u03BF\u03AF\u03BF \u03C0\u03B1\u03C1\u03BF\u03C5\u03C3\u03B9\u03AC\u03B6\u03B5\u03C4\u03B1\u03B9
    \u03C4\u03BF \u03C6\u03AC\u03C1\u03BC\u03B1\u03BA\u03BF \u03C9\u03C2 \xAB \u03B4\u03C5\u03BD\u03B1\u03C4\u03CC
    \xBB \u03B4\u03B5\u03BD \u03B5\u03AF\u03BD\u03B1\u03B9 \u03BF \u03B9\u03B4\u03B1\u03BD\u03B9\u03BA\u03CC\u03C2
    \u03B3\u03B9\u03B1 \u03CC\u03BB\u03BF\u03C5\u03C2 \u03C4\u03BF\u03C5\u03C2 \u03B1\u03BD\u03B8\u03C1\u03CE\u03C0\u03BF\u03C5\u03C2
    . \u03A3\u03B5 \u03BA\u03AC\u03C0\u03BF\u03B9\u03BF\u03C5\u03C2 \u03B1\u03C3\u03B8\u03B5\u03BD\u03B5\u03AF\u03C2
    \u03BC\u03C0\u03BF\u03C1\u03B5\u03AF \u03BD\u03B1 \u03B4\u03B7\u03BC\u03B9\u03BF\u03C5\u03C1\u03B3\u03AE\u03C3\u03B5\u03B9
    \u03BC\u03B9\u03B1 \u03B8\u03B5\u03C4\u03B9\u03BA\u03AE \u03C0\u03C1\u03BF\u03C3\u03B4\u03BF\u03BA\u03AF\u03B1
    \u03CC\u03C4\u03B9 \u03C4\u03BF \u03C6\u03AC\u03C1\u03BC\u03B1\u03BA\u03BF \u03B8\u03B1
    \u03B4\u03C1\u03AC\u03C3\u03B5\u03B9 \u03B3\u03C1\u03AE\u03B3\u03BF\u03C1\u03B1
    \u03BA\u03B1\u03B9 \u03CC\u03C4\u03B1\u03BD \u03B1\u03C5\u03C4\u03CC \u03B4\u03B5\u03BD
    \u03C3\u03C5\u03BC\u03B2\u03B5\u03AF \u03BD\u03B9\u03CE\u03B8\u03BF\u03C5\u03BD
    \u03B1\u03C0\u03BF\u03B3\u03BF\u03AE\u03C4\u03B5\u03C5\u03C3\u03B7 \u03B5\u03C6\u03CC\u03C3\u03BF\u03BD
    \u03BA\u03AC\u03C4\u03B9 \u03C0\u03BF\u03C5 \u03B5\u03AF\u03BD\u03B1\u03B9 \xAB
    \u03B4\u03C5\u03BD\u03B1\u03C4\u03CC \xBB \u03B4\u03B5\u03BD \u03C4\u03BF\u03C5\u03C2
    \u03B2\u03BF\u03AE\u03B8\u03B7\u03C3\u03B5. \u03A3\u03B5 \u03AC\u03BB\u03BB\u03BF\u03C5\u03C2
    \u03B1\u03C3\u03B8\u03B5\u03BD\u03B5\u03AF\u03C2 \u03B7 \u03AD\u03BA\u03C6\u03C1\u03B1\u03C3\u03B7
    \xAB\u03B4\u03C5\u03BD\u03B1\u03C4\u03CC \xBB \u03BC\u03C0\u03BF\u03C1\u03B5\u03AF
    \u03BD\u03B1 \u03B4\u03B7\u03BC\u03B9\u03BF\u03C5\u03C1\u03B3\u03AE\u03C3\u03B5\u03B9
    \u03C4\u03B7\u03BD \u03B1\u03AF\u03C3\u03B8\u03B7\u03C3\u03B7 \u03CC\u03C4\u03B9
    \u03C4\u03BF \u03C6\u03AC\u03C1\u03BC\u03B1\u03BA\u03BF \u03B1\u03C5\u03C4\u03CC
    \u03BC\u03C0\u03BF\u03C1\u03B5\u03AF \u03BD\u03B1 \u03AD\u03C7\u03B5\u03B9 \u03BA\u03B1\u03B9
    \u03C0\u03BF\u03BB\u03BB\u03AD\u03C2 \u03C0\u03B1\u03C1\u03B5\u03BD\u03AD\u03C1\u03B3\u03B5\u03B9\u03B5\u03C2.
    \u0397 \u03B5\u03C0\u03B9\u03BB\u03BF\u03B3\u03AE \u03C4\u03BF\u03C5 \u03C4\u03C1\u03CC\u03C0\u03BF\u03C5
    \u03BC\u03B5 \u03C4\u03BF\u03BD \u03BF\u03C0\u03BF\u03AF\u03BF \u03C0\u03B1\u03C1\u03BF\u03C5\u03C3\u03B9\u03AC\u03B6\u03BF\u03C5\u03BC\u03B5
    \u03C4\u03BF \u03C6\u03AC\u03C1\u03BC\u03B1\u03BA\u03BF \u03C3\u03C4\u03BF\u03BD
    \u03B1\u03C3\u03B8\u03B5\u03BD\u03AE \u03B5\u03AF\u03BD\u03B1\u03B9 \u03C0\u03BF\u03BB\u03CD
    \u03C3\u03B7\u03BC\u03B1\u03BD\u03C4\u03B9\u03BA\u03AE \u03B3\u03B9\u03B1\u03C4\u03AF
    \u03C3\u03C5\u03BD\u03C4\u03B5\u03AF\u03BD\u03B5\u03B9 \u03C3\u03C4\u03B7\u03BD
    \u03B4\u03B7\u03BC\u03B9\u03BF\u03C5\u03C1\u03B3\u03AF\u03B1 \u03B8\u03B5\u03C1\u03B1\u03C0\u03B5\u03C5\u03C4\u03B9\u03BA\u03AE\u03C2
    \u03C3\u03C5\u03BC\u03BC\u03B1\u03C7\u03AF\u03B1\u03C2 \u03B1\u03BD\u03AC\u03BC\u03B5\u03C3\u03B1
    \u03C3\u03C4\u03BF\u03BD \u03B5\u03C0\u03B1\u03B3\u03B3\u03B5\u03BB\u03BC\u03B1\u03C4\u03AF\u03B1
    \u03C5\u03B3\u03B5\u03AF\u03B1\u03C2 \u03BA\u03B1\u03B9 \u03B1\u03C5\u03C4\u03CC\u03BD
    \u03BC\u03AD\u03C3\u03B1 \u03B1\u03C0\u03CC \u03C4\u03B9\u03C2 \u03C0\u03C1\u03BF\u03C3\u03B4\u03BF\u03BA\u03AF\u03B5\u03C2
    \u03C0\u03BF\u03C5 \u03C4\u03BF\u03C5 \u03B4\u03B7\u03BC\u03B9\u03BF\u03C5\u03C1\u03B3\u03BF\u03CD\u03BD\u03C4\u03B1\u03B9
    \u03B3\u03B9\u03B1 \u03C4\u03B7\u03BD \u03B8\u03B5\u03C1\u03B1\u03C0\u03B5\u03C5\u03C4\u03B9\u03BA\u03AE
    \u03C0\u03B1\u03C1\u03AD\u03BC\u03B2\u03B1\u03C3\u03B7."

  m_text: "\u03A3\u03B5 \u03B1\u03C5\u03C4\u03CC \u03C4\u03BF \u03C3\u03B7\u03BC\u03B5\u03AF\u03BF
    \u03C4\u03B7\u03C2 \u03B4\u03B9\u03B5\u03C1\u03B5\u03CD\u03BD\u03B7\u03C3\u03B7\u03C2
    \u03B1\u03C5\u03C4\u03AE \u03B7 \u03C0\u03BB\u03B7\u03C1\u03BF\u03C6\u03BF\u03C1\u03AF\u03B1
    \u03B4\u03B5\u03BD \u03B8\u03B1 \u03C0\u03C1\u03BF\u03C3\u03B8\u03AD\u03C3\u03B5\u03B9
    \u03C3\u03B7\u03BC\u03B1\u03BD\u03C4\u03B9\u03BA\u03AD\u03C2 \u03C0\u03BB\u03B7\u03C1\u03BF\u03C6\u03BF\u03C1\u03AF\u03B5\u03C2
    \u03B3\u03B9\u03B1 \u03C4\u03B7\u03BD \u03B1\u03C1\u03C7\u03B9\u03BA\u03AE \u03BC\u03B1\u03C2
    \u03B5\u03BA\u03C4\u03AF\u03BC\u03B7\u03C3\u03B7 \u03C4\u03BF\u03C5 \u03C0\u03B5\u03C1\u03B9\u03C3\u03C4\u03B1\u03C4\u03B9\u03BA\u03BF\u03CD.
    \u03A0\u03A1\u039F\u03A3\u039F\u03A7\u0397: \u03B1\u03C5\u03C4\u03CC \u03B4\u03B5\u03BD
    \u03C3\u03B7\u03BC\u03B1\u03AF\u03BD\u03B5\u03B9 \u03CC\u03C4\u03B9 \u03B1\u03C5\u03C4\u03AE
    \u03B7 \u03C0\u03BB\u03B7\u03C1\u03BF\u03C6\u03BF\u03C1\u03AF\u03B1 \u03B4\u03B5\u03BD
    \u03B5\u03AF\u03BD\u03B1\u03B9 \u03C3\u03B7\u03BC\u03B1\u03BD\u03C4\u03B9\u03BA\u03AE
    \u03B3\u03B9\u03B1 \u03C4\u03B7\u03BD \u03C3\u03C5\u03BD\u03BF\u03BB\u03B9\u03BA\u03AE
    \u03BA\u03BB\u03B9\u03BD\u03B9\u03BA\u03AE \u03B5\u03BA\u03C4\u03AF\u03BC\u03B7\u03C3\u03B7
    \u03B1\u03C0\u03BB\u03AC \u03CC\u03C4\u03B9 \u03C3\u03C4\u03B1 \u03C0\u03BB\u03B1\u03AF\u03C3\u03B9\u03B1
    \u03C4\u03B7\u03C2 \u03B1\u03C1\u03C7\u03B9\u03BA\u03AE\u03C2 \u03BA\u03B1\u03C4\u03B1\u03BD\u03CC\u03B7\u03C3\u03B7\u03C2
    \u03C4\u03C9\u03BD \u03B1\u03BD\u03B1\u03B3\u03BA\u03CE\u03BD \u03C4\u03BF\u03C5
    \u03B1\u03C3\u03B8\u03B5\u03BD\u03BF\u03CD\u03C2 \u03B4\u03B5\u03BD \u03B5\u03AF\u03BD\u03B1\u03B9
    \u03B1\u03C5\u03C4\u03CC \u03C0\u03BF\u03C5 \u03B8\u03B1 \u03BB\u03AD\u03B3\u03B1\u03BC\u03B5
    \u03BA\u03C1\u03AF\u03C3\u03B9\u03BC\u03B7 \u03C0\u03BB\u03B7\u03C1\u03BF\u03C6\u03BF\u03C1\u03AF\u03B1."
